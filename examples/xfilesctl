	lang=${LANG:-en_US}
	lang=${lang%%.*}
	lang=${lang%@*}
	case "$lang" in
		(ar_SA*|ar*) printf '%s\n' ar_SA ;;
		(zh_CN*|zh*|zh_Hans*|zh_SG*) printf '%s\n' zh_CN ;;
		(nl_NL*|nl*) printf '%s\n' nl_NL ;;
		(fr_FR*|fr*) printf '%s\n' fr_FR ;;
