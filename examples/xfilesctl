warn() {
	printf '%s: %s\n' "${0##*/}" "$*" >&2
}

err() {
	warn "$@"
	exit 1
}

menu() {
	xmenu
}

edit() {
	xterm -into "$WINDOWID" -bw 0 -e "$EDITOR" -- "$@"
}

asktext() {
	label="$1"
	tmp="${TMPDIR:-/tmp}/xfilesctl-input-$$"
	rm -f -- "$tmp"
	: > "$tmp" || return 1
	xterm -into "$WINDOWID" -bw 0 -title "$label" -e "$EDITOR" -- "$tmp"
	status=$?
	if [ $status -ne 0 ]; then
		rm -f -- "$tmp"
		return 1
	fi
	value=$(sed -n '/^[[:space:]]*$/d; {p; q;}' "$tmp")
	rm -f -- "$tmp"
	printf '%s\n' "$value"
}

confirm() {
	prompt="$1"
	"$ask" || return 0
		choice=$(printf '%s\n\t%s\n\t%s\n' "$prompt" "$L_YES" "$L_NO" | menu)
	case "$choice" in
	("$L_YES") return 0 ;;
	(*) return 1 ;;
	esac
}

setuniquepath() {
	basename="${1##*/}"
	dirname="${1%/*}"
	body="${basename%.*}"
	ext="${basename##"$body"}"
	unset -v i p
	while test -e "$dirname/$body$p$i$ext"
	do
		p="-"
		if [ -z "$i" ]; then i=1; else i=$((i + 1)); fi
	done
	uniquepath="$dirname/$body$p$i$ext"
}

save_clipboard_state() {
	mkdir -p "$STATE_DIR" || return 1
	: > "$STATE_FILE" || return 1
	printf 'mode=%s\n' "$1" > "$STATE_FILE" || return 1
	shift
	for file; do printf '%s\n' "$file"; done >> "$STATE_FILE"
}

load_clipboard_state() {
	clipboard_mode=
	clipboard_paths=
	[ -r "$STATE_FILE" ] || return 1
	IFS= read -r first < "$STATE_FILE" || return 1
	case "$first" in
	(mode=*) clipboard_mode=${first#mode=} ;;
	(*) return 1 ;;
	esac
	clipboard_paths=$(sed '1d' "$STATE_FILE")
	return 0
}

copy_here() {
	for file; do
		setuniquepath "$PWD/${file##*/}"
		cp -R -- "$file" "$uniquepath"
	done
}

move_here() {
	for file; do
		setuniquepath "$PWD/${file##*/}"
		mv -- "$file" "$uniquepath"
	done
}

link_here() {
	for file; do
		setuniquepath "$PWD/${file##*/}"
		ln -s -- "$file" "$uniquepath"
	done
}

istrashdir() {
	[ "$1" = "$TRASH_DIR" ]
}

trash() {
	case $# in (0) return ;; esac
	mkdir -m 700 -p -- "$TRASH_DIR" "$TRASH_INFO_DIR" || exit 1
	for file; do
		test -e "$file" || continue
		istrashdir "$file" && continue
		setuniquepath "$TRASH_DIR/${file##*/}"
		mv -- "$file" "$uniquepath" && \
		cat > "$TRASH_INFO_DIR/${uniquepath##*/}.trashinfo" <<EOF
[Trash Info]
Path=$file
DeletionDate=$(date +"%FT%H:%M:%S")
EOF
	done
}

restore() {
	case $# in (0) return ;; esac
	for file; do
		basename="${file##*/}"
		infofile="$TRASH_INFO_DIR/$basename.trashinfo"
		origfile="$(sed -En '/^[[:blank:]]*Path[[:blank:]]*=/{s/.*=[[:blank:]]*//;p;q;}' < "$infofile")"
		test -n "$origfile" || continue
		if test -e "$origfile"; then
			warn "$basename: file already exists on original directory"
			continue
		fi
		case "$origfile" in (*/*) mkdir -p -- "${origfile%/*}" || continue ;; esac
		mv -- "$file" "$origfile" && rm -f -- "$infofile"
	done
}

emptytrash() {
	mkdir -m 700 -p -- "$TRASH_DIR" "$TRASH_INFO_DIR" || return 1
	find "$TRASH_DIR" -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +
	find "$TRASH_INFO_DIR" -mindepth 1 -maxdepth 1 -exec rm -f -- {} +
}

copyclip() { case $# in (0) return ;; esac; save_clipboard_state copy "$@" || return; }
cutclip() { case $# in (0) return ;; esac; save_clipboard_state cut "$@" || return; }

paste() {
	set --
	if load_clipboard_state; then
		while IFS= read -r f; do [ -n "$f" ] && set -- "$@" "$f"; done <<EOF
$clipboard_paths
EOF
		case "$clipboard_mode" in
		(cut) move_here "$@" ;;
		(copy) copy_here "$@" ;;
		esac
	fi
}

rename() {
	case "$#" in
	(0) return ;;
	(1) istrashdir "$1" && return ;;
	esac
	unset -v tempfile tempdir TMPDIR
	trap '
		test "$tempfile" && rm -f -- "$tempfile" 2>/dev/null
		test "$tempdir" && rmdir -- "$tempdir" 2>/dev/null
		exit
	' EXIT HUP
	tempfile="$(mktemp)" || exit 1
	tempdir="$(mktemp -d -p "$PWD")" || exit 1
	for file; do
		file="${file#"$PWD/"}"
		case "$file" in
		("") err "empty argument" ;;
		(*[[:cntrl:]]*) err "renaming files containing control characters is not supported" ;;
		([[:space:]]*|*[[:space:]]) err "renaming files beginning or ending in space is not supported" ;;
		esac
		printf '%s\n' "$file" >> "$tempfile"
	done
	edit "$tempfile" || exit 1
	mv -- "$@" "$tempdir" || exit 1
	while read -r target; do
		source="$tempdir/${1##*/}"
		if test -z "$target"; then
			trash "$source"
		else
			case "$target" in (*/*) mkdir -p -- "${target%/*}" ;; esac
			case "$target" in (/*|./*|../*) ;; (*) target="$PWD/$target" ;; esac
			setuniquepath "$target"
			mv -- "$source" "$uniquepath"
		fi
		shift
	done < "$tempfile"
	{ mv -- "$tempdir/"* ./; rmdir -- "$tempdir"; rm -f -- "$tempfile"; } 2>/dev/null
}

newfile() {
	name=$(asktext "$L_NEW_FILE") || return
	[ -n "$name" ] || return
	case "$name" in (*/*) return ;; esac
	setuniquepath "$PWD/$name"
	: > "$uniquepath"
}

newfolder() {
	name=$(asktext "$L_NEW_FOLDER") || return
	[ -n "$name" ] || return
	case "$name" in (*/*) return ;; esac
	setuniquepath "$PWD/$name"
	mkdir -p -- "$uniquepath"
}

sortby() {
	choice="$1"
	[ -n "$choice" ] || return
	xprop -id "$WINDOWID" -format "_CONTROL_SORTBY" 8u -set "_CONTROL_SORTBY" "$choice" >/dev/null 2>&1
}

changedir() {
	xprop -id "$WINDOWID" -format "_CONTROL_GOTO" 8u -set "_CONTROL_GOTO" "$1" >/dev/null 2>&1
}

dropmenu() {
	option=$(printf '%s\n%s\n%s\n' "$L_COPY" "$L_MOVE" "$L_LINK" | menu)
	case "$option" in
	("$L_COPY") copy_here "$@" ;;
	("$L_MOVE") move_here "$@" ;;
	("$L_LINK") link_here "$@" ;;
	esac
}

dirmenu() {
	option=$(cat <<EOF | menu
$L_GO_UP
$L_PASTE
$L_SORT
	$L_NAME
	$L_TIME
	$L_SIZE
$L_NEW_FILE
$L_NEW_FOLDER
EOF
)
	case "$option" in
	("$L_GO_UP") changedir ".." ;;
	("$L_PASTE") paste ;;
	("$L_NAME") sortby name ;;
	("$L_TIME") sortby time ;;
	("$L_SIZE") sortby size ;;
	("$L_NEW_FILE") newfile ;;
	("$L_NEW_FOLDER") newfolder ;;
	esac
}

filemenu() {
	if [ "$#" -eq 1 ] && istrashdir "$1"; then
		option=$(printf '%s\n' "$L_EMPTY_TRASH" | menu)
		case "$option" in ("$L_EMPTY_TRASH") emptytrash ;; esac
		return
	fi
	option=$(case "$PWD" in
	("$TRASH_DIR") cat <<EOF
$L_COPY
$L_RESTORE
EOF
		;;
	(*) cat <<EOF
$L_CUT
$L_COPY
$L_RENAME
$L_MOVE_TO_TRASH
$L_EDIT
EOF
		;;
	esac | menu)
	case "$option" in
	("$L_CUT") cutclip "$@" ;;
	("$L_COPY") copyclip "$@" ;;
	("$L_RENAME") rename "$@" ;;
	("$L_MOVE_TO_TRASH") trash "$@" ;;
	("$L_RESTORE") restore "$@" ;;
	("$L_EDIT") edit "$1" & ;;
	esac
}

operation="$1"
shift 1
for file; do
	shift 1
	case "$file" in
	("") continue ;;
	([!/]* ) file="$PWD/$file" ;;
	esac
	set -- "$@" "$file"
done
case "$operation" in
("menu") case "$#" in (0) dirmenu "$@" ;; (*) filemenu "$@" ;; esac ;;
("drop-ask") case "$PWD" in ("$TRASH_DIR") trash "$@" ;; (*) dropmenu "$@" ;; esac ;;
("drop-copy") case "$PWD" in ("$TRASH_DIR") trash "$@" ;; (*) copy_here "$@" ;; esac ;;
("drop-move") case "$PWD" in ("$TRASH_DIR") trash "$@" ;; (*) move_here "$@" ;; esac ;;
("drop-link") case "$PWD" in ("$TRASH_DIR") trash "$@" ;; (*) link_here "$@" ;; esac ;;
(^BackSpace) changedir ".." ;;
(^F2) rename "$@" ;;
(^F5|^[Rr]) changedir "." ;;
(^[Cc]) copyclip "$@" ;;
(^[Xx]) cutclip "$@" ;;
(^[Pp]|^[Vv]) paste ;;
(^Delete)
	case "$PWD" in ("$TRASH_DIR") restore "$@" ;; (*) trash "$@" ;; esac
	;;
esac
